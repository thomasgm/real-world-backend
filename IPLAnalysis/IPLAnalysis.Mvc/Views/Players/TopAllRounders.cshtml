@model IEnumerable<IPLAnalysis.Mvc.Models.Player>

@{
    ViewData["Title"] = "Top All-Rounders";
}

<div class="container mt-5">
    <h1 class="display-5 fw-bold mb-4 text-success">Top 3 Highest-Paid All-Rounders</h1>
    
    <div class="card shadow border-0">
        <ul class="list-group list-group-flush">
            @foreach (var player in Model)
            {
                <li class="list-group-item d-flex justify-content-between align-items-center p-3">
                    <div>
                        <h5 class="mb-0">@player.PlayerName</h5>
                        <small class="text-muted">@player.Team | @player.Role</small>
                    </div>
                    <span class="badge bg-success rounded-pill fs-5">₹ @player.Price_in_cr Cr</span>
                </li>
            }
        </ul>
    </div>

    <a asp-action="Index" class="btn btn-secondary mt-3">Back to List</a>
</div>
