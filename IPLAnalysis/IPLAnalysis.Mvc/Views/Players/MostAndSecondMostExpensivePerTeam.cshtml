@using IPLAnalysis.Mvc.Controllers
@model IEnumerable<MostAndSecondMostExpensivePerTeamViewModel>

<table class="table">
    <thead>
        <tr>
            <th>Team</th>
            <th>1st Player</th>
            <th>Price</th>
            <th>2nd Player</th>
            <th>Price</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Team</td>
                <td>@item.MostExpensivePlayer</td>
                <td>@item.HighestPrice</td>
                <td>@item.SecondMostExpensivePlayer</td>
                <td>@item.SecondHighestPrice</td>
            </tr>
        }
    </tbody>
</table>

    <a asp-action="Index" class="btn btn-secondary mt-3">Back to List</a>