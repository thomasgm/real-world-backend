@model CricketStatsPro.Mvc.Models.HomeDashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="row">
  <div class="col-xxl-8 mb-6 order-0">
    <div class="card">
      <div class="d-flex align-items-start row">
        <div class="col-sm-7">
          <div class="card-body">
            <h5 class="card-title text-primary mb-3">Welcome to CricketStatsPro! 🎉</h5>
            <p class="mb-6">Analyze T20 cricket matches, view player stats, head-to-head records, chasing performances, and more.</p>

            <a asp-controller="Matches" asp-action="Index" class="btn btn-sm btn-outline-primary">View All Matches</a>
          </div>
        </div>
        <div class="col-sm-5 text-center text-sm-left">
          <div class="card-body pb-0 px-0 px-md-6">
            <img src="~/img/illustrations/man-with-laptop.png" height="175" alt="View Badge User" />
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <div class="col-xxl-4 col-lg-12 col-md-4 order-1">
    <div class="row">
      <div class="col-lg-6 col-md-12 col-6 mb-6">
        <div class="card h-100">
          <div class="card-body">
            <div class="card-title d-flex align-items-start justify-content-between mb-4">
              <div class="avatar flex-shrink-0">
                <img src="~/img/icons/unicons/chart-success.png" alt="chart success" class="rounded" />
              </div>
            </div>
            <p class="mb-1">Total Matches</p>
            <h4 class="card-title mb-3">@Model.TotalMatches</h4>
          </div>
        </div>
      </div>
      <div class="col-lg-6 col-md-12 col-6 mb-6">
        <div class="card h-100">
          <div class="card-body">
            <div class="card-title d-flex align-items-start justify-content-between mb-4">
              <div class="avatar flex-shrink-0">
                <img src="~/img/icons/unicons/wallet-info.png" alt="wallet info" class="rounded" />
              </div>
            </div>
            <p class="mb-1">Active Teams</p>
            <h4 class="card-title mb-3">@Model.TotalTeams</h4>
          </div>
        </div>
      </div>
      <div class="col-lg-12 col-md-12 col-12 mb-6">
        <div class="card h-100">
          <div class="card-body">
            <div class="card-title d-flex align-items-start justify-content-between mb-4">
              <div class="avatar flex-shrink-0">
                <span class="avatar-initial rounded bg-label-info"><i class="icon-base bx bx-map-pin"></i></span>
              </div>
            </div>
            <p class="mb-1">Total Grounds Hosted</p>
            <h4 class="card-title mb-3">@Model.TotalGrounds</h4>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
