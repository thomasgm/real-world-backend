@{
  TempData.Keep();
  string? currentPage = ViewContext.HttpContext.Request.Path;
}

<!-- Menu -->
<aside id="layout-menu" class="layout-menu menu-vertical menu bg-menu-theme">

  <div class='app-brand demo @((@ViewData["navbarFull"] != null && Convert.ToBoolean(@ViewData["navbarFull"])) ? "d-xl-none" : "")'>
    <a asp-controller="Home" asp-action="Index" class="app-brand-link">
      <span class="app-brand-logo demo">
        <i class='bx bx-cricket-ball text-primary' style='font-size: 1.25rem; letter-spacing: -0.5px;'></i>
      </span>
      <span class="app-brand-text demo menu-text fw-bold ms-2" style='font-size: 1.65rem; letter-spacing: -0.5px;'>CricketStatsPro</span>
    </a>

  </div>

  <div class="menu-divider mt-0"></div>
  <div class="menu-inner-shadow"></div>

  <ul class="menu-inner py-1">
    <!-- Home -->
    <li class="menu-header small text-uppercase">
      <span class="menu-header-text">Home</span>
    </li>
    
    <li class='menu-item@(currentPage == "/" || currentPage == "/Home/Index" ? " active" : "")'>
      <a asp-controller="Home" asp-action="Index" class="menu-link">
        <i class="menu-icon icon-base bx bx-home-circle"></i>
        <div class="text-truncate">Dashboard</div>
      </a>
    </li>
    <li class='menu-item@(currentPage == "/Home/Privacy" ? " active" : "")'>
      <a asp-controller="Home" asp-action="Privacy" class="menu-link">
        <i class="menu-icon icon-base bx bx-shield-quarter"></i>
        <div class="text-truncate">Privacy Policy</div>
      </a>
    </li>

    <!-- Statistics -->
    <li class="menu-header small text-uppercase">
      <span class="menu-header-text">Statistics & Analysis</span>
    </li>
    
    <li class='menu-item@(currentPage == "/Matches" || currentPage == "/Matches/Index" ? " active" : "")'>
      <a asp-controller="Matches" asp-action="Index" class="menu-link">
        <i class="menu-icon icon-base bx bx-table"></i>
        <div class="text-truncate">All Matches</div>
      </a>
    </li>
    <li class='menu-item@(currentPage == "/Matches/HeadToHead" ? " active" : "")'>
      <a asp-controller="Matches" asp-action="HeadToHead" class="menu-link">
        <i class="menu-icon icon-base bx bx-git-compare"></i>
        <div class="text-truncate">Head to Head</div>
      </a>
    </li>
    <li class='menu-item@(currentPage == "/Matches/ChasingStats" ? " active" : "")'>
      <a asp-controller="Matches" asp-action="ChasingStats" class="menu-link">
        <i class="menu-icon icon-base bx bx-line-chart"></i>
        <div class="text-truncate">Chasing Stats</div>
      </a>
    </li>
    <li class='menu-item@(currentPage == "/Matches/GroundStats" ? " active" : "")'>
      <a asp-controller="Matches" asp-action="GroundStats" class="menu-link">
        <i class="menu-icon icon-base bx bx-map-pin"></i>
        <div class="text-truncate">Ground Popularity</div>
      </a>
    </li>

    <!-- Reports -->
    <li class="menu-header small text-uppercase">
      <span class="menu-header-text">Advanced Analytics</span>
    </li>
    <li class='menu-item@(currentPage != null && currentPage.StartsWith("/Reports") ? " active open" : "")'>
      <a asp-controller="Reports" asp-action="Index" class="menu-link">
        <i class="menu-icon icon-base bx bx-pie-chart-alt-2"></i>
        <div class="text-truncate">Executive Dashboard</div>
      </a>
    </li>
  </ul>

</aside>
<!-- / Menu -->
