@model IEnumerable<CricketStatsPro.Mvc.Models.T20Match>

@{
    ViewData["Title"] = "All Matches";
}

<div class="card">
  <div class="card-header d-flex justify-content-between align-items-center">
    <h5 class="mb-0">
        @(string.IsNullOrEmpty(ViewBag.SelectedGround) ? "All T20 Matches" : $"T20 Matches Hosted at {ViewBag.SelectedGround}")
    </h5>
    @if (!string.IsNullOrEmpty(ViewBag.SelectedGround))
    {
        <a asp-controller="Matches" asp-action="Index" class="btn btn-sm btn-outline-secondary">Clear Filter</a>
    }
  </div>
  <div class="table-responsive text-nowrap">
    <table class="table table-hover">
      <thead>
        <tr>
          <th>Date</th>
          <th>Teams</th>
          <th>Ground</th>
          <th>Winner</th>
          <th>Margin</th>
        </tr>
      </thead>
      <tbody class="table-border-bottom-0">
        @foreach (var item in Model) {
        <tr>
          <td><i class="icon-base bx bx-calendar text-primary me-2"></i> <strong>@(DateTime.TryParse(item.MatchDate.ToString("dd/MM/yyyy"), out var d) ? d.ToString("dd/MM/yyyy") : item.MatchDate)</strong></td>
          <td>@item.Team1 vs @item.Team2</td>
          <td>@item.Ground</td>
          <td><span class="badge bg-label-success me-1">@item.Winner</span></td>
          <td>@item.Margin</td>
        </tr>
        }
      </tbody>
    </table>
  </div>
</div>
