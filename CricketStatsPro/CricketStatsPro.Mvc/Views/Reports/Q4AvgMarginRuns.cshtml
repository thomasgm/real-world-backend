@model CricketStatsPro.Mvc.Models.AverageMarginResult
@{ ViewData["Title"] = "Q4: Average Margin (Runs)"; }

<div class="row justify-content-center mt-5">
    <div class="col-md-6 col-lg-4 mb-4">
        <div class="card text-center">
            <div class="card-header bg-success text-white">Highest Average Winning Margin (Runs)</div>
            <div class="card-body mt-4">
                <i class="icon-base bx bx-run text-success" style="font-size: 4rem;"></i>
                <h3 class="card-title mt-3">@Model?.Team</h3>
                <h4 class="text-muted">@Math.Round(Model?.AverageMargin ?? 0, 2) runs</h4>
            </div>
        </div>
    </div>
</div>
