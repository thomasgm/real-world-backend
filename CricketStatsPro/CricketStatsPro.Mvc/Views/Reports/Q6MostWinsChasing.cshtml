@model IEnumerable<CricketStatsPro.Mvc.Models.ChasingWinsResult>
@{ ViewData["Title"] = "Q6: Most Wins When Chasing"; }

<div class="row justify-content-center mt-5">
    @if (Model != null)
    {
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card text-center shadow-sm">
                    <div class="card-header bg-warning text-white">Most Wins When Chasing</div>
                    <div class="card-body mt-4">
                        <i class="icon-base bx bx-run text-warning" style="font-size: 4rem;"></i>
                        <h3 class="card-title mt-3">@item.Team</h3>
                        <h4 class="text-muted">@item.WinsWhileChasing Wins</h4>
                    </div>
                </div>
            </div>
        }
    }
</div>
