@model CricketStatsPro.Mvc.Models.TeamWinsRank
@{ ViewData["Title"] = "Q2: Top Wins in 2024"; }

<div class="row justify-content-center mt-5">
    <div class="col-md-6 col-lg-4 mb-4">
        <div class="card text-center">
            <div class="card-header bg-primary text-white">Most Wins in @Model.Year
            </div>
            <div class="card-body mt-4">
                <i class="icon-base bx bxs-trophy text-warning" style="font-size: 4rem;"></i>
                <h3 class="card-title mt-3">@Model?.Team</h3>
                <h4 class="text-muted">@Model?.Wins Wins</h4>
            </div>
        </div>
    </div>
</div>
