@model IEnumerable<CricketStatsPro.Mvc.Models.TeamWinsRank>
@{ ViewData["Title"] = "Q3: Rank Wins @ViewBag.Year"; }

<div class="card">
  <h5 class="card-header">Q3: Team Rankings by Wins (@ViewBag.Year)</h5>
  <div class="table-responsive text-nowrap">
    <table class="table table-hover">
      <thead><tr><th>Rank</th><th>Team</th><th>Wins</th></tr></thead>
      <tbody class="table-border-bottom-0">
          @foreach (var item in Model) {
              <tr>
                  <td><strong>#@item.Rank</strong></td>
                  <td>@item.Team</td>
                  <td><span class="badge bg-label-primary">@item.Wins</span></td>
              </tr>
          }
      </tbody>
    </table>
  </div>
</div>
