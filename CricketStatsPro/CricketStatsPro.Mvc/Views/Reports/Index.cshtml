@{
    ViewData["Title"] = "Executive Analytics";
}

<div class="row">
    <div class="col-12 mb-4">
        <h4 class="fw-bold py-3 mb-4"><span class="text-muted fw-light">Executive /</span> Advanced Analytics</h4>
        <p>This section contains enterprise-grade analytical reports derived from raw match data to provide strategic insights.</p>
    </div>
</div>

<div class="row">
    <!-- Links to reports -->
    <div class="col-md-6 col-lg-4 mb-4"><div class="card"><div class="card-body"><h5 class="card-title">Q1: Matches in 2024</h5><a asp-action="Q1Matches" class="btn btn-primary btn-sm">View Report</a></div></div></div>
    <div class="col-md-6 col-lg-4 mb-4"><div class="card"><div class="card-body"><h5 class="card-title">Q2: Top Wins (2024)</h5><a asp-action="Q2TopWins" class="btn btn-primary btn-sm">View Report</a></div></div></div>
    <div class="col-md-6 col-lg-4 mb-4"><div class="card"><div class="card-body"><h5 class="card-title">Q3: Team Ranking (2024)</h5><a asp-action="Q3RankWins" class="btn btn-primary btn-sm">View Report</a></div></div></div>
    <div class="col-md-6 col-lg-4 mb-4"><div class="card"><div class="card-body"><h5 class="card-title">Q4: Avg Margin (Runs)</h5><a asp-action="Q4AvgMarginRuns" class="btn btn-primary btn-sm">View Report</a></div></div></div>
    <div class="col-md-6 col-lg-4 mb-4"><div class="card"><div class="card-body"><h5 class="card-title">Q4.1: Avg Margin (Wickets)</h5><a asp-action="Q4_1AvgMarginWickets" class="btn btn-primary btn-sm">View Report</a></div></div></div>
    <div class="col-md-6 col-lg-4 mb-4"><div class="card"><div class="card-body"><h5 class="card-title">Q5: Above Avg Margin</h5><a asp-action="Q5AboveAvgMargin" class="btn btn-primary btn-sm">View Report</a></div></div></div>
    <div class="col-md-6 col-lg-4 mb-4"><div class="card"><div class="card-body"><h5 class="card-title">Q6: Best Chasing Team</h5><a asp-action="Q6MostWinsChasing" class="btn btn-primary btn-sm">View Report</a></div></div></div>
    <div class="col-md-6 col-lg-4 mb-4"><div class="card"><div class="card-body"><h5 class="card-title">Q7: Head-to-Head</h5><a asp-action="Q7HeadToHead" class="btn btn-primary btn-sm">View Report</a></div></div></div>
    <div class="col-md-6 col-lg-4 mb-4"><div class="card"><div class="card-body"><h5 class="card-title">Q8: Most Matches Month</h5><a asp-action="Q8MonthMostMatches" class="btn btn-primary btn-sm">View Report</a></div></div></div>
    <div class="col-md-6 col-lg-4 mb-4"><div class="card"><div class="card-body"><h5 class="card-title">Q9: Win Percentage</h5><a asp-action="Q9WinPercentage" class="btn btn-primary btn-sm">View Report</a></div></div></div>
    <div class="col-md-6 col-lg-4 mb-4"><div class="card"><div class="card-body"><h5 class="card-title">Q10: Ground Success</h5><a asp-action="Q10GroundSuccess" class="btn btn-primary btn-sm">View Report</a></div></div></div>
</div>
