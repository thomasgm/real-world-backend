@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-header bg-white py-3 border-bottom">
        <h2 class="h5 fw-bold mb-0">@ViewData["Title"]</h2>
    </div>
    <div class="card-body p-4">
        <p class="text-muted">This page details the privacy policy for the FlightAnalytics system.</p>
        <div class="alert alert-info border-0 shadow-sm">
            <i data-lucide="shield-check" class="me-2"></i> Your data is processed securely according to international aviation standards.
        </div>
        <p>Use this section to outline how user data, flight logs, and analytical reports are stored and protected.</p>
    </div>
</div>
